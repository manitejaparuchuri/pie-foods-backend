PORT=3000
CATALOG_DATA_SOURCE=mysql
AUTH_PROVIDER=local

# Use either the DB_* variables below or Railway MySQL variables
# (MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=piefruits

