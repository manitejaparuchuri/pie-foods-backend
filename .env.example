BREVO_FROM_EMAIL=verified_sender@example.com
BREVO_FROM_NAME=Pie Foods
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

CORS_ALLOWED_ORIGINS=http://localhost:4200

R2_ACCOUNT_ID=your_r2_account_id
